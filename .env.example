# CrawlKit Configuration

# Server Port
PORT=8080

# Supabase (required for authentication & storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key-here

# Master API Key (for admin access)
CRAWLKIT_MASTER_KEY=ck_master_your_secret_key_here

# Optional: Playwright browser path
PLAYWRIGHT_BROWSERS_PATH=/ms-playwright

# Optional: Database connection (if using direct PostgreSQL)
DATABASE_URL=postgres://user:password@host:5432/database
SUPABASE_DB_PASSWORD=your-database-password

# Optional: Railway deployment
RAILWAY_TOKEN=your-railway-token
RAILWAY_PROJECT_ID=your-project-id
RAILWAY_ENVIRONMENT_ID=your-environment-id
RAILWAY_SERVICE_ID=your-service-id
